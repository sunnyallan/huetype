# Copy this file to .env and fill in your values for local development.
# On Render.com, set these as Environment Variables in the dashboard.
# NEVER commit .env to git.

# ── Supabase ───────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# Local dev:
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
# Production (add your domain):
# ALLOWED_ORIGINS=https://www.sunnyallan.design
